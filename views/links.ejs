<% var pageTitle = 'NamelessUnSee - recipient links'; %>
<%- include('partials/head', { pageTitle: pageTitle }) %>
<%- include('partials/nav') %>
<div class="wrap">
  <p><a href="/dashboard">- Dashboard</a></p>
  <h1>Recipient links<% if (image.title) { %> - <%= image.title %><% } %></h1>
  <% if (created) { %><div class="notice">Link created.</div><% } %>

  <div class="card" style="max-width:720px">
    <p class="muted" style="margin-top:0">Hand each person their own link and the
      access log will show which link every view came through. A one-time link
      stops working after its first view. Revoking a link blocks it immediately;
      the plain share link keeps working either way. Recipient links do not expose
      the image's plain share token.</p>
    <form method="post" action="/dashboard/i/<%= encodeURIComponent(image.token) %>/links">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <label for="label">Label (who gets this link?)</label>
      <input type="text" id="label" name="label" maxlength="80" placeholder="e.g. Alex">
      <label for="max_uses">View limit (optional)</label>
      <input type="text" id="max_uses" name="max_uses" inputmode="numeric" placeholder="unlimited">
      <label class="check" style="font-weight:400"><input type="checkbox" name="one_time" style="width:auto"> One-time: stop working after the first view</label>
      <p><button class="btn small" type="submit">Create link</button></p>
    </form>
  </div>

  <% if (links.length) { %>
  <div class="card scroll" style="max-width:960px">
    <table>
      <thead><tr><th>Label</th><th>Link</th><th>Views</th><th>Limit</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% for (const link of links) { %>
        <tr>
          <td><%= link.label || '-' %></td>
          <td class="mono" style="word-break:break-all"><%= baseUrl %>/r/<%= link.token %></td>
          <td><%= link.use_count %></td>
          <td><%= link.max_uses || 'unlimited' %></td>
          <td>
            <% if (link.revoked_at) { %><span class="pill rejected">revoked</span>
            <% } else if (link.max_uses && link.use_count >= link.max_uses) { %><span class="pill pending">used up</span>
            <% } else { %><span class="pill approved">active</span><% } %>
          </td>
          <td>
            <% if (!link.revoked_at) { %>
            <form method="post" action="/dashboard/i/<%= encodeURIComponent(image.token) %>/links/<%= link.id %>/revoke">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <button class="btn danger small" type="submit">Revoke</button>
            </form>
            <% } %>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<%- include('partials/foot') %>
