# ---------------------------------------------------------------------------
# unsee configuration
# Copy this file to .env and fill in the values. Never commit your real .env.
# ---------------------------------------------------------------------------

# Public base URL of the deployment (used to build share links).
# When served through a Cloudflare Tunnel this is your public hostname.
BASE_URL=http://localhost:3000

# Operator identity shown in the Terms of Service and Privacy Policy. Set these
# for any public deployment- they are the legal point of contact. Have the ToS
# and Privacy Policy reviewed by counsel for your jurisdiction before launch.
OPERATOR_NAME=
OPERATOR_CONTACT=
OPERATOR_JURISDICTION=

# Port the Node server listens on (inside the container).
PORT=3000

# Source-code link shown in the footer and on the license/acknowledgement pages.
# Defaults to the upstream repository; point it at your fork if you modify the
# code (NNCL requires corresponding source to be available).
# SOURCE_URL=https://github.com/NanashiTheNameless/NamelessUnSee

# Secret used to sign session/consent cookies. MUST be a long random string.
# Generate a strong 128-char URL-safe secret with:
#   LEN=128; BYTES=$((((LEN+3)/4)*3)); openssl rand -base64 "$BYTES" | tr '+/' '-_' | tr -d '\n=' | head -c "$LEN"; echo
COOKIE_SECRET=change-me-to-a-long-random-string

# Set to "true" in production (behind HTTPS / Cloudflare) so cookies are
# only sent over secure connections.
SECURE_COOKIES=false

# Where the SQLite database and uploaded originals live (persist this volume).
DATA_DIR=./data

# How long an uploaded image is retained before it is purged, in hours.
IMAGE_TTL_HOURS=24

# Default maximum upload size in megabytes. Admins can override this per user.
MAX_UPLOAD_MB=500
# Absolute parser ceiling for any per-user upload override.
MAX_UPLOAD_HARD_MB=4096
# Default active storage quota per user. Admins can override this per user.
MAX_STORAGE_MB=1024

# ---------------------------------------------------------------------------
# Encrypted media storage. New originals are always encrypted with AES-256-GCM
# before they are written to local storage or uploaded to Cloudflare R2. Use a
# 64-character hex key in production; if omitted, COOKIE_SECRET derives it.
# ---------------------------------------------------------------------------
# Production recommendation: r2. Use local only for development.
STORAGE_BACKEND=local
STORAGE_ENCRYPTION_KEY=
# Cloudflare R2 S3 API credentials. R2_ACCOUNT_ID derives the standard endpoint;
# set R2_ENDPOINT instead when using a custom endpoint.
R2_ACCOUNT_ID=
# R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_FORCE_PATH_STYLE=false
# Generic S3-compatible fallback (only needed when STORAGE_BACKEND=s3).
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=false

# ---------------------------------------------------------------------------
# Rate limiting (per client IP; uploads and reports are per user). The default
# in-memory store suits a single instance. For multiple instances, share the
# counters through Redis: set RATELIMIT_STORE=redis, point REDIS_URL at your
# server, and run `yarn add redis`. If Redis is missing or down the limiter
# falls back to in-memory and keeps serving.
# ---------------------------------------------------------------------------
RATELIMIT_ENABLED=true
RATELIMIT_STORE=memory
# REDIS_URL=redis://localhost:6379
RL_LOGIN_MAX=10           # per RL_LOGIN_WINDOW_MIN (default 15) minutes
RL_SIGNUP_MAX=5           # per RL_SIGNUP_WINDOW_MIN (default 60) minutes
RL_UPLOAD_MAX=30          # per RL_UPLOAD_WINDOW_MIN (default 60) minutes, per user
RL_VIEW_MAX=120           # per RL_VIEW_WINDOW_SEC (default 60) seconds
RL_TELEMETRY_MAX=60       # per RL_TELEMETRY_WINDOW_SEC (default 60) seconds

# ---------------------------------------------------------------------------
# Content moderation. Scans the uploaded original once on upload; videos are
# sampled at equal distances throughout (5-15 frames based on duration).
#   - Perceptual-hash blocklist (self-managed, always on): auto-quarantines
#     uploads matching a hash you added from the admin review page.
#   - NSFW classifier sidecar (optional): routes suspected content to HUMAN
#     REVIEW only. It never auto-bans or auto-reports. Docker Compose runs it
#     as the internal `moderation` service and caches the ONNX model in its own
#     volume. If the sidecar is unavailable, uploads are held for admin review
#     when NSFW_FAIL_CLOSED=true.
#   - Known-CSAM providers (Cloudflare / PhotoDNA / Arachnid): scaffolding only,
#     disabled- they require vetted access. See docs/CONTEXT.md.
# Nothing here ever auto-bans a user; account actions require an admin.
# ---------------------------------------------------------------------------
MODERATION_ENABLED=true
MODERATION_HOLD_ON_REVIEW=true   # hold review-flagged images until an admin decides
MODERATION_PHASH_THRESHOLD=10    # legacy 64-bit blocklist entries: max Hamming distance
MODERATION_PDQ_THRESHOLD=31      # 256-bit PDQ entries: max Hamming distance (PDQ convention)
NSFW_CLASSIFIER_ENABLED=true
NSFW_MODEL=onnx-community/nsfw-classifier-ONNX
NSFW_SAFETY_MODEL=OwenElliott/image-safety-classifier-m
NSFW_BINARY_MODEL=onnx-community/nsfw_image_detection-ONNX
# Internal moderation sidecar URL. Docker Compose sets this automatically.
# NSFW_SERVICE_URL=http://moderation:8787
NSFW_SERVICE_TIMEOUT_MS=15000
NSFW_THRESHOLD=0.80
NSFW_FAIL_CLOSED=true
# Future known-CSAM providers (leave disabled unless you have vetted access):
MOD_CLOUDFLARE_ENABLED=false
MOD_PHOTODNA_ENABLED=false
PHOTODNA_ENDPOINT=
PHOTODNA_API_KEY=
MOD_ARACHNID_ENABLED=false
ARACHNID_ENDPOINT=
ARACHNID_API_KEY=

# ---------------------------------------------------------------------------
# IP intelligence- 100% LOCAL detection (no per-viewer third-party calls).
# The app auto-downloads and auto-refreshes these datasets on its own; viewer
# IPs never leave your server. Country is always available for free from
# Cloudflare's CF-IPCountry header. Detection runs only on the image VIEW route.
# ---------------------------------------------------------------------------

# Refuse VPN/proxy/Tor viewers, and refuse when the viewer can't be assessed.
BLOCK_PROXIES=true
BLOCK_ON_UNKNOWN=true
BLOCK_DATACENTER=true

# Allow loopback/LAN addresses (enable ONLY for local development so rendering
# works without a real public IP). Keep false in production.
ALLOW_PRIVATE_IPS=false

# --- MaxMind GeoLite2 (geolocation + network/ASN) --------------------------
# Preferred geo/ASN source. Get a FREE licence key at
# https://www.maxmind.com/en/geolite2/signup and paste it here; the app then
# downloads GeoLite2-ASN and GeoLite2-City and keeps them up to date (verifying
# MaxMind's published SHA-256). Alternatively, mount your own .mmdb files at the
# paths below and leave the key blank. Without either, geo falls back to the
# Cloudflare country header only.
# NOTE: since 2024 MaxMind redirects downloads to an R2 presigned URL. The app
# follows redirects automatically; if you run a strict egress firewall, allow
# HTTPS to download.maxmind.com AND
# mm-prod-geoip-databases.a2649acb697e2c09b632799562c076f2.r2.cloudflarestorage.com
MAXMIND_LICENSE_KEY=
# MAXMIND_ASN_DB=./data/intel/GeoLite2-ASN.mmdb
# MAXMIND_CITY_DB=./data/intel/GeoLite2-City.mmdb
MAXMIND_REFRESH_HOURS=72

# --- Tor exit list ---------------------------------------------------------
TOR_LIST_ENABLED=true
# TOR_LIST_URL=https://check.torproject.org/torbulkexitlist
TOR_REFRESH_HOURS=6

# --- VPN / datacenter ranges (X4BNet/lists_vpn) ----------------------------
# Both variables take a comma-separated list of URLs, and each source may mix
# IPv4 and IPv6 CIDRs. The X4BNet defaults cover IPv4 only, so append an IPv6
# source of your choosing to extend coverage, e.g.:
#   DATACENTER_LIST_URL=https://raw.githubusercontent.com/X4BNet/lists_vpn/main/output/datacenter/ipv4.txt,https://example.invalid/datacenter-ipv6.txt
VPN_LISTS_ENABLED=true
# VPN_LIST_URL=https://raw.githubusercontent.com/X4BNet/lists_vpn/main/output/vpn/ipv4.txt
# DATACENTER_LIST_URL=https://raw.githubusercontent.com/X4BNet/lists_vpn/main/output/datacenter/ipv4.txt
VPN_REFRESH_HOURS=24

# ---------------------------------------------------------------------------
# Optional: notify admins by email when a new account needs approval, an upload
# is flagged for moderation, or a report is submitted.
# Requires a Resend API key. Leave RESEND_API_KEY empty to disable (the app
# will just log pending approvals to the server console instead).
# ---------------------------------------------------------------------------
RESEND_API_KEY=
ADMIN_NOTIFY_FROM=NamelessUnSee <NamelessUnSee@example.invalid>
ADMIN_NOTIFY_TO=admin@example.invalid

# Email 2FA is required by default. Resend must be configured for login codes.
TWOFA_ENABLED=true
# Development-only fallback. Keep false in production; otherwise codes are logged.
TWOFA_CONSOLE_FALLBACK=false
TWOFA_CHALLENGE_MIN=5

# At most 6 leak reports per account per 24 hours by default.
RL_REPORT_WINDOW_MIN=1440
RL_REPORT_MAX=6
# Max size per leak-report screenshot, in megabytes.
MAX_REPORT_MB=25

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (used by docker-compose, not by the Node app itself).
# Create a tunnel in the Cloudflare Zero Trust dashboard and paste its token.
# ---------------------------------------------------------------------------
TUNNEL_TOKEN=
